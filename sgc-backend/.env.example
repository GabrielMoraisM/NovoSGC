# Copie este arquivo para .env e preencha os valores antes de rodar o backend
# cp .env.example .env

DATABASE_URL=postgresql://usuario:senha@host:5432/sgc_dev
SECRET_KEY=gere-uma-chave-segura-aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development

# ================================================================
# ACTIVE DIRECTORY / LDAP
# Preencher junto com o gestor de TI
# ================================================================
LDAP_ENABLED=false
LDAP_SERVER=ldap://IP_DO_AD
LDAP_USE_SSL=false
LDAP_BASE_DN=DC=dominio,DC=corp
LDAP_DEFAULT_PERFIL=GESTOR
LDAP_FALLBACK_LOCAL=true
