# =============================================================
# Configurações do banco de dados
# =============================================================
DATABASE_URL=postgresql://usuario:senha@servidor:5432/banco

# =============================================================
# JWT
# =============================================================
SECRET_KEY=troque-por-uma-chave-aleatoria-longa
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Ambiente: development | production
ENVIRONMENT=development

# =============================================================
# Active Directory / LDAP
# Preencher junto com o gestor de TI
# =============================================================

# Habilita a integração (true/false)
LDAP_ENABLED=false

# Endereço do servidor AD — perguntar ao TI
#   Exemplo sem SSL:  ldap://10.40.20.10
#   Exemplo com SSL:  ldaps://ad.heca.com.br
LDAP_SERVER=

# Usar SSL/TLS? (recomendado em produção junto com LDAPS)
LDAP_USE_SSL=false

# Base DN do domínio — perguntar ao TI
#   Exemplo: DC=heca,DC=com,DC=br
LDAP_BASE_DN=

# Perfil padrão para colaboradores que logam pela primeira vez via AD
# Opções: ADMIN | GESTOR | FINANCEIRO | AUDITOR | TI
LDAP_DEFAULT_PERFIL=GESTOR

# Se o servidor AD estiver fora do ar, tenta a senha local do SGC?
# true  = sim (mais resiliente)
# false = não (mais seguro — bloqueia se AD cair)
LDAP_FALLBACK_LOCAL=true
